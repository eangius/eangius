---
import { getCollection } from "astro:content";
import { useTranslations, getLocale } from "../../i18n/utils";
import ProjectCard from "./ProjectCard.astro";

const t = useTranslations(getLocale(Astro.currentLocale));

const projects = (await getCollection("projects", ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section id="projects" class="mx-auto max-w-5xl px-4 py-16">
  <h2 class="text-2xl font-bold text-text sm:text-3xl">{t("projects.title")}</h2>
  <p class="mt-2 text-text-muted">{t("projects.subtitle")}</p>

  <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      projects.map((project) => (
        <ProjectCard
          slug={project.id}
          title={project.data.title}
          summary={project.data.summary}
          thumbnail={project.data.thumbnail}
          tags={project.data.tags}
        />
      ))
    }
  </div>
</section>
