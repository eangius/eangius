---
import { useTranslations, getLocale } from "../../i18n/utils";
import { skillCategories, type SkillCategoryColor } from "../../data/skills";
import Icon from "../ui/Icon.astro";

const t = useTranslations(getLocale(Astro.currentLocale));

// Static class strings (so Tailwind's scanner picks them up at build time).
const colorClasses: Record<SkillCategoryColor, string> = {
  purple: "bg-purple-500/10 text-purple-500",
  red: "bg-red-500/10 text-red-500",
  green: "bg-green-500/10 text-green-500",
  orange: "bg-orange-500/10 text-orange-500",
};
---

<section id="skills" class="mx-auto max-w-5xl px-4 py-16">
  <h2 class="text-2xl font-bold text-text sm:text-3xl">{t("skills.title")}</h2>
  <p class="mt-2 text-text-muted">{t("skills.subtitle")}</p>

  <div class="mt-8 grid gap-6 sm:grid-cols-2">
    {
      skillCategories.map((category) => (
        <div class="rounded-lg border border-border bg-surface p-6">
          <div class="mb-4 flex items-center gap-3">
            <Icon name={category.icon} class={`h-9 w-9 rounded-md p-2 ${colorClasses[category.color]}`} />
            <h3 class="text-lg font-semibold text-text">{category.title}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {category.skills.map((skill) => (
              <span
                class={`inline-flex items-center rounded-md border border-border px-2.5 py-0.5 text-xs font-semibold ${colorClasses[category.color]}`}
              >
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>