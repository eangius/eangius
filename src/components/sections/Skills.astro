---
import { useTranslations, getLocale } from "../../i18n/utils";
import { skillCategories } from "../../data/skills";
import StarRating from "../ui/StarRating.astro";

const t = useTranslations(getLocale(Astro.currentLocale));
---

<section id="skills" class="mx-auto max-w-5xl px-4 py-16">
  <h2 class="text-2xl font-bold text-text sm:text-3xl">{t("skills.title")}</h2>
  <p class="mt-2 text-text-muted">{t("skills.subtitle")}</p>

  <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {
      skillCategories.map((category) => (
        <div class="rounded-lg border border-border bg-surface p-5">
          <h3 class="font-semibold text-accent">{category.title}</h3>
          <ul class="mt-3 space-y-2">
            {category.skills.map((skill) => (
              <li class="flex items-center justify-between gap-2 text-sm text-text-muted">
                <span>{skill.name}</span>
                <StarRating level={skill.level} />
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
