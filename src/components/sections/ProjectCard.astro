---
interface Props {
  slug: string;
  title: string;
  summary: string;
  thumbnail?: string;
  tags: string[];
}

const { slug, title, summary, thumbnail = "/images/projects/placeholder.svg", tags } = Astro.props;
const href = `/projects/${slug}/`;
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-lg border border-border bg-bg transition-shadow hover:shadow-lg"
>
  <img
    src={thumbnail}
    alt=""
    width="400"
    height="240"
    loading="lazy"
    class="h-40 w-full object-cover"
  />
  <div class="flex flex-1 flex-col gap-3 p-5">
    <h3 class="font-semibold text-text group-hover:text-accent">{title}</h3>
    <p class="flex-1 text-sm text-text-muted">{summary}</p>
    {
      tags.length > 0 && (
        <ul class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <li class="rounded-full bg-blue-500/10 px-2.5 py-1 text-xs font-semibold text-blue-500">
              {tag}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</a>
